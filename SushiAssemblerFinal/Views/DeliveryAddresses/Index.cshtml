@model IEnumerable<SushiAssemblerFinal.Models.DeliveryAddress>

@{
    ViewData["Title"] = "Your Delivery Addresses";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add address</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Recipient</th>
            <th>Phone</th>
            <th>Street</th>
            <th>City</th>
            <th>Default</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var item in Model) {
    <tr>
        <td>@item.RecipientName</td>
        <td>@item.Phone</td>
        <td>@item.Street</td>
        <td>@item.City</td>
        <td>@(item.IsDefault ? "Yes" : "")</td>
        <td>
            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
